    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^9.33.0",
    "less": "^4.6.4",
    "vite": "^6.0.5",
    "vite-plugin-mock": "^3.0.2",
    "vite-plugin-qiankun": "^1.0.15",
