    "@types/html2canvas": "^1.0.0",
    "@yss-ui/components": "^1.2.9",
    "@yss-ui/hooks": "^1.0.16",
    "@yss-ui/utils": "^1.0.5",
    "alova": "^3.4.1",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.13.6",
    "dayjs": "^1.11.19",
    "json-bigint": "^1.0.0",
